        fi

        if [ "$__mode" = "required" ]; then
            __mode=none
            __i=$((__i + 1))
            continue
        fi

        if [ "$__mode" = "optional" ] || [ "$__mode" = "variadic" ]; then
            local __candidate
            if [ -n "$__path" ]; then
                __candidate="$__path $__w"
            else
                __candidate="$__w"
            fi
            if [ "${__w#-}" != "$__w" ] || ___copilot_is_known_path "$__candidate"; then
